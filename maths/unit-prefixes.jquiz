% jquiz Unit prefixes

% multichoice
text: Which prefix means 10<sup>3</sup>?
@answer
text: k (kilo)
correct: true
@answer
text: M (mega)
correct: false
@answer
text: c (centi)
correct: false
@answer
text: m (milli)
correct: false


